{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "permission": {
    "read": {
      "*": "allow",
      "secrets/**": "ask",
      "~/.ssh/**": "deny",
      "~/.aws/**": "ask"
    },
    "edit": {
      "*": "ask",
      "secrets/**": "deny",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "*": "ask",
      "python *": "deny",
      "python3 *": "deny",

      "ls *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git commit *": "deny",
      "git push *": "deny",

      "gh pr view *": "allow",

      "head *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "which *": "allow",
      "wc *": "allow",
      "jq *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "sleep *": "allow",
      "sort *": "allow",
      "true *": "allow",
      "uniq *": "allow",

      "kubectl config *": "allow",
      "kubectl cluster-info *": "allow",
      "kubectl api-resources *": "allow",
      "kubectl get *": "allow",
      "kubectl describe *": "allow",
      "kubectl logs *": "allow",
      "kubectl top *": "allow",

      "docker ps *": "allow",
      "docker images *": "allow",
      "docker logs *": "allow",
      "docker inspect *": "allow",
      "docker compose ps *": "allow",
      "docker compose config *": "allow",
      "docker context ls *": "allow",

      "tofu init *": "allow",
      "tofu validate *": "allow",
      "tofu plan *": "allow",
      "tofu show *": "allow",
      "tofu state show *": "allow",
      "tofu state list *": "allow",
      "tofu output *": "allow",
      "tofu providers *": "allow",
      "tofu fmt -check *": "allow",

      "aws configure list *": "allow",
      "aws sts get-caller-identity *": "allow",
      "aws s3 ls *": "allow",
      "aws * describe-* *": "allow",
      "aws ec2 get-* *": "allow",
      "aws eks list-* *": "allow",
      "aws iam list-* *": "allow",
      "aws iam get-* *": "allow",
      "aws logs get-* *": "allow",

      "jsonnet *": "allow"
    }
  }
}
