#!/usr/bin/env bash

print_total_for_com() {
    hledger balance assets --flat cur:"$1" -V -X USD | tail -n 1 | awk '{print $1}'
}

hledger balance assets --flat | sed '1,/^-*$/d' | # quoting ':' is fun...
awk '{gsub(/^"|"$/, "", $2); print $2}' | 
(while read -r commodity; do
    echo -n "$commodity "
    print_total_for_com "$commodity"
done) |
awk '{v[$1]=$2; total+=$2} END {for (i in v) printf "%s %.2f%%\n", i, v[i]/total*100}' | sort -k2,2nr
